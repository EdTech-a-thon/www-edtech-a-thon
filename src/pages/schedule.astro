---
import Layout from "../components/Layout.astro";

const educatorSignupLink =
  "https://docs.google.com/forms/d/e/1FAIpQLSfl48Ojnct2gYtCREvf6d0-OxcJa0QHBfkdRxbdOWf4_V23FQ/viewform?usp=dialog";

type ScheduleEvent = {
  start: string;
  end: string;
  title: string;
  description: string;
  note?: string;
};

type ScheduleDay = {
  label: string;
  date: string;
  timezones: { zone: string; range: string }[];
  events: ScheduleEvent[];
};

const days: ScheduleDay[] = [
  {
    label: "Day 1",
    date: "Monday, July 20",
    timezones: [
      { zone: "Eastern (ET)", range: "10:00 AM – 12:00 PM" },
      { zone: "Central (CT)", range: "9:00 AM – 11:00 AM" },
      { zone: "Pacific (PT)", range: "7:00 AM – 9:00 AM" },
    ],
    events: [
      {
        start: "10:00 AM",
        end: "10:15 AM",
        title: "Welcome to EdTech-a-thon!",
        description:
          "Join us for the EdTech-a-thon kick-off! This is where it all begins. Meet the EdTech-a-thon staff and the educators joining us from around the globe, get a quick tour of how the three days will run, and find out how to make the most of every workshop and networking session. Come say hello and get settled in before we dive in.",
      },
      {
        start: "10:15 AM",
        end: "11:00 AM",
        title: "Educator Lightning Talks",
        description:
          "Rapid-fire lightning talks spotlighting teachers with great workflows and practical tips & tricks for using technology in the classroom. Each speaker shares a quick spotlight on how they've integrated technology into the classroom, so you can hopefully take some tips & tricks home with you.",
      },
      {
        start: "11:10 AM",
        end: "12:00 PM",
        title: "Educator Pair & Share",
        description:
          "Meet educators from around the globe in fun, fast-paced online ice breaker discussions. We'll break into small groups to talk through the problems you submitted, rapidly brainstorm solutions together, and learn from what other teachers are already doing. A great way to meet people who teach similar subjects, face similar hurdles, or are just cool to know.",
      },
    ],
  },
  {
    label: "Day 2",
    date: "Tuesday, July 21",
    timezones: [
      { zone: "Eastern (ET)", range: "10:00 AM – 12:00 PM" },
      { zone: "Central (CT)", range: "9:00 AM – 11:00 AM" },
      { zone: "Pacific (PT)", range: "7:00 AM – 9:00 AM" },
    ],
    events: [
      {
        start: "10:00 AM",
        end: "10:10 AM",
        title: "Welcome to EdTech-a-thon Day 2!",
        description:
          "Welcome back! We'll kick off Day 2 with a quick recap of yesterday and fresh updates on our development team's progress — what's been built so far, what's in flight, and what to look forward to in today's workshops.",
      },
      {
        start: "10:10 AM",
        end: "11:00 AM",
        title: "Artificial Intelligence 101",
        description:
          "A crash course in the good, the bad, and the ugly of Large Language Models (LLMs). How were these things first created? Where do they fail in dangerous ways? How are different AI companies handling your data? What's actually good about them — and why have we decided to use them for our development at EdTech-a-thon? By the end you'll be able to describe how AI works at a high level, understand how your data can be used by different AI companies, and reason about when an LLM should and shouldn't be applied to a problem.",
      },
      {
        start: "11:10 AM",
        end: "12:00 PM",
        title: "Vibe Coding Workshop",
        description:
          "Learn how to use AI to build useful apps for yourself! By the end of the session, you'll have created your own website that actually lives on the internet. Literally 0 prerequisite knowledge is required — you do not need to know how to code, be technical, or have ever touched AI before. If you're creative and excited to build something, please join! You'll pick up basic prompt-engineering techniques for vibe coding (plan mode, effort levels, and context engineering) and walk away with a live website of your own.",
        note: "Please join on a laptop — this is a hands-on session and you'll be building as we go.",
      },
    ],
  },
  {
    label: "Day 3",
    date: "Wednesday, July 22",
    timezones: [
      { zone: "Eastern (ET)", range: "2:00 PM – 4:00 PM" },
      { zone: "Central (CT)", range: "1:00 PM – 3:00 PM" },
      { zone: "Pacific (PT)", range: "11:00 AM – 1:00 PM" },
    ],
    events: [
      {
        start: "2:00 PM",
        end: "2:50 PM",
        title: "Team Presentations",
        description:
          "Our developer and educator teams take the stage to present the solutions they built during the event — walking through the problem each tool tackles, how it works, and what's next. Watch the teams demo what they've made before you get hands-on with the tools yourself in the Gallery Walk that follows.",
      },
      {
        start: "3:00 PM",
        end: "3:45 PM",
        title: "Gallery Walk",
        description:
          "Your chance to get hands-on. Test out the tools our developers built during the event, explore how they'd fit into your classroom, and give us your honest feedback before they launch. Your input here directly shapes the free, open-source tools we ship this fall.",
      },
      {
        start: "3:50 PM",
        end: "4:00 PM",
        title: "Closing Remarks",
        description:
          "We wrap up EdTech-a-thon with a few final thank-yous, a look back at everything the community built and discussed over the three days, and what comes next — including how we'll keep you in the loop on the open-source tools heading to your classroom this fall.",
      },
    ],
  },
];
---

<Layout title="Schedule">
  <section class="flex flex-col gap-5">
    <p class="text-sm font-extrabold uppercase tracking-wide text-primary-700">
      Event Schedule
    </p>
    <h1 class="font-display text-5xl leading-tight text-slate-950 sm:text-6xl">
      Three days, day by day
    </h1>
    <p class="max-w-2xl text-lg leading-8 text-slate-700">
      We received over 600 problem submissions from educators around the world,
      and we're hosting free virtual workshops and events from July 20–22 so you
      can collaborate with other educators and learn practical EdTech skills
      you'll actually use. Sign up by day and drop in for as many days as you'd
      like!
    </p>
    <p
      class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-400 bg-slate-100 px-4 py-2 text-sm font-bold text-slate-700"
    >
      <span aria-hidden="true">⚠️</span> All times are shown in Eastern Time (ET)
    </p>
    <div class="flex flex-col gap-3 sm:flex-row">
      <a
        href={educatorSignupLink}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-primary-200 px-5 py-3 text-sm font-bold text-primary-900 transition hover:bg-primary-100"
      >
        Sign Up to Attend
      </a>
    </div>
  </section>

  {
    days.map((day) => (
      <section
        class="border-t border-slate-200 pt-10"
        aria-labelledby={`${day.label.replace(/\s+/g, "-").toLowerCase()}-heading`}
      >
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-extrabold uppercase tracking-wide text-primary-700">
              {day.label}
            </p>
            <h2
              id={`${day.label.replace(/\s+/g, "-").toLowerCase()}-heading`}
              class="font-display text-4xl text-slate-950"
            >
              {day.date}
            </h2>
          </div>
          <dl class="flex flex-wrap gap-x-6 gap-y-1 text-sm">
            {day.timezones.map((tz) => (
              <div class="flex items-baseline gap-2">
                <dt class="font-bold text-slate-500">{tz.zone}</dt>
                <dd class="font-semibold text-slate-900">{tz.range}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="mt-6 grid gap-5 lg:grid-cols-3">
          {day.events.map((event) => (
            <article class="flex flex-col border border-slate-400 border-b-4 bg-white rounded-lg">
              <div class="flex flex-1 flex-col p-6">
                <p class="text-sm font-extrabold uppercase tracking-wide text-primary-700">
                  {event.start} – {event.end}
                </p>
                <h3 class="mt-2 text-xl font-extrabold leading-tight text-slate-950">
                  {event.title}
                </h3>
                <p class="mt-3 text-base leading-7 text-slate-700">
                  {event.description}
                </p>
              </div>
              {event.note && (
                <p class="border-t w-full border-dashed border-slate-400 bg-slate-100 rounded-b-md px-6 py-4 text-sm font-semibold text-slate-700">
                  {event.note}
                </p>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  }

  <section
    class="border-t border-slate-200 pt-10"
    aria-labelledby="schedule-cta-heading"
  >
    <div class="border border-slate-400 border-b-4 bg-white rounded-lg">
      <div class="p-6">
        <h2
          id="schedule-cta-heading"
          class="text-2xl font-extrabold text-slate-950 sm:text-3xl"
        >
          Ready to join us?
        </h2>
        <p class="mt-1 text-lg leading-7 text-slate-700">
          Attendance is completely free. Sign up by day and drop in for as many
          days as you'd like.
        </p>
        <a
          href={educatorSignupLink}
          target="_blank"
          rel="noreferrer"
          class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-primary-200 px-5 py-3 text-sm font-bold text-primary-900 transition hover:bg-primary-100 sm:w-auto"
        >
          Sign Up to Attend
        </a>
      </div>
      <p
        class="text-slate-600 text-base border-t w-full border-dashed border-slate-400 bg-slate-100 rounded-b-md px-6 py-4"
      >
        Or email us about joining in-person at <a
          href="mailto:directors@edtechathon.com"
          class="underline decoration-dashed decoration-2 decoration-slate-700/50 underline-offset-4 hover:bg-slate-100 hover:decoration-solid"
          >directors@edtechathon.com</a
        >
      </p>
    </div>
  </section>
</Layout>

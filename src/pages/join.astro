---
import Layout from "../components/Layout.astro";
---

<Layout title="Join">
  <section class="grid gap-8 lg:grid-cols-[1fr_320px] lg:items-center">
    <div class="flex flex-col gap-5">
      <p class="text-sm font-extrabold uppercase tracking-wide text-primary-700">
        Virtual EdTech-a-thon
      </p>
      <h1 class="font-display text-5xl leading-tight text-slate-950 sm:text-6xl">
        Zoom room coming soon
      </h1>
      <p class="max-w-2xl text-lg leading-8 text-slate-700">
        The virtual room for EdTech-a-thon will be posted here before the event.
        Check back closer to July 20, 2026 for the live Zoom link.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-full bg-primary-200 px-5 py-3 text-sm font-bold text-primary-900 transition hover:bg-primary-100"
        >
          Back to Event Details
        </a>
        <a
          href="mailto:directors@edtechathon.com"
          class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-800 transition hover:bg-slate-50"
        >
          Contact Organizers
        </a>
      </div>
    </div>

    <aside
      class="border border-slate-400 border-b-4 bg-white p-6 rounded-lg"
      aria-label="Virtual room status"
    >
      <div
        class="flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-800"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-8 w-8"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m22 8-6 4 6 4V8Z" />
          <rect width="14" height="12" x="2" y="6" rx="2" />
        </svg>
      </div>
      <h2 class="mt-6 text-2xl font-extrabold text-slate-950">
        Room not open yet
      </h2>
      <p class="mt-3 text-base leading-7 text-slate-700">
        We will update this page with the Zoom access details when the virtual
        event space is ready.
      </p>
      <dl class="mt-6 grid gap-3 border-t border-dashed border-slate-300 pt-5">
        <div>
          <dt class="text-xs font-extrabold uppercase text-slate-500">Event</dt>
          <dd class="mt-1 font-semibold text-slate-900">July 20 - 22, 2026</dd>
        </div>
        <div>
          <dt class="text-xs font-extrabold uppercase text-slate-500">
            Format
          </dt>
          <dd class="mt-1 font-semibold text-slate-900">
            In-person and virtual
          </dd>
        </div>
      </dl>
    </aside>
  </section>
</Layout>
